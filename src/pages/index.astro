---
/**
 * Головна сторінка портфоліо.
 * Тут задаються SEO, порядок секцій і загальна структура сторінки.
 * Розмітка кожної секції — у src/components/sections/.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/sections/HeroSection.astro";
import AtmosSection from "../components/sections/AtmosSection.astro";
import FpvSection from "../components/sections/FpvSection.astro";
import WebsitesSection from "../components/sections/WebsitesSection.astro";
import AboutSection from "../components/sections/AboutSection.astro";

const page = {
  title: "Sviatoslav Cherenov — Systems Architect",
  description:
    "Від ідеї до робочого прототипу: проектую залізо, пишу low-level код та створюю кросплатформенні інтерфейси",
};

const sections = [
  HeroSection,
  AtmosSection,
  FpvSection,
  WebsitesSection,
  AboutSection,
] as const;
---

<BaseLayout title={page.title} description={page.description}>
  <div
    data-layer="Portfolio"
    class="Portfolio w-full mx-auto min-w-0 bg-neutral-800 flex flex-col justify-start items-center overflow-hidden"
  >
    {sections.map((Section) => <Section />)}
  </div>
</BaseLayout>
