  class="Websites w-full self-stretch flex flex-col justify-center items-center overflow-hidden bg-stone-950"
>
  <div
    data-layer="Main container"
    class="MainContainer w-full max-w-[1440px] px-6 md:px-12 xl:px-20 py-20 md:py-32 flex flex-col justify-center items-center gap-20 md:gap-28 lg:gap-36 min-w-0"
  >
    <div
