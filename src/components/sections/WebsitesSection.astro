---
import SocialBtn from "../SocialBtn.astro";
---

<div
  data-layer="Websites"
  class="Websites w-full bg-[url('/apps-bg.webp')] bg-cover bg-center self-stretch overflow-hidden"
>
  <div
    data-layer="darkAndBlur"
    class="darkAndBlur bg-black/60 backdrop-blur-[8px] w-full min-h-screen flex justify-center items-center overflow-hidden"
  >
    <div
      data-layer="Main container"
      class="MainContainer w-full max-w-360 px-4 md:px-8 py-16 md:py-24 flex flex-col justify-center items-center gap-16 md:gap-24 xl:gap-30 min-w-0"
    >
      <div
        data-layer="Title"
        class="w-full flex flex-col items-center text-center gap-4"
      >
        <h2
          class="text-white text-4xl md:text-5xl font-medium font-['Inter'] filter drop-shadow-[0_4px_6px_rgba(0,0,0,0.5)]"
        >
          Вебсайти та Застосунки
        </h2>
        <p
          class="text-white/80 text-body-lg font-normal font-['Inter'] max-w-5xl"
        >
          Приклади моїх робіт: деякі фото та назви були замінені задля
          конфіденційності
        </p>
      </div>

      <div
        data-layer="Dance Studio"
        class="w-full flex flex-col items-center gap-8"
      >
        <div
          class="w-full flex flex-col sm:flex-row justify-between items-center gap-4 border-b border-white/5 pb-4"
        >
          <h3 class="text-white text-2xl font-medium font-['Inter']">
            Dance Studio Landing
          </h3>
          <SocialBtn
            href="https://www.behance.net/gallery/250566641/Dance-Studio-Landing"
            platform="behance"
            text="View on Behance"
          />
        </div>

        <div
          class="w-full flex flex-col lg:flex-row justify-center items-center gap-8 filter drop-shadow-[0_20px_40px_rgba(0,0,0,0.55)]"
        >
          <div class="w-full max-w-[947px] aspect-[947/698] p-[1px]">
            <img
              src="./vdc.webp"
              alt="Desktop preview"
              class="w-full h-full object-contain"
            />
          </div>
          <div class="w-full max-w-[280px] aspect-[280/600] shrink-0 p-[1px]">
            <img
              src="./vdc-mobile.webp"
              alt="Mobile preview"
              class="w-full h-full object-contain"
            />
          </div>
        </div>
      </div>

      <div
        data-layer="Foundation"
        class="w-full flex flex-col items-center gap-8"
      >
        <div
          class="w-full flex flex-col sm:flex-row justify-between items-center gap-4 border-b border-white/5 pb-4"
        >
          <h3 class="text-white text-2xl font-medium font-['Inter']">
            Сайт Благодійного фонду
          </h3>
          <SocialBtn
            href="https://www.behance.net/gallery/250626393/Charity-Landing-Design"
            platform="behance"
            text="View on Behance"
          />
        </div>

        <div
          class="w-full flex flex-col md:flex-row justify-center items-center gap-8 filter drop-shadow-[0_20px_40px_rgba(0,0,0,0.55)]"
        >
          <div class="w-full aspect-[16/9] p-[1px]">
            <img
              src="./foundation.webp"
              alt="Foundation desktop 1"
              class="w-full h-full object-contain"
            />
          </div>
          <div class="w-full aspect-[16/9] p-[1px]">
            <img
              src="./foundation-2.webp"
              alt="Foundation desktop 2"
              class="w-full h-full object-contain"
            />
          </div>
        </div>
      </div>

      <div
        data-layer="Pinguin"
        class="w-full p-6 md:p-10 bg-white/5 rounded-sm border border-white/10 backdrop-blur-md flex flex-col gap-10 shadow-2xl"
      >
        <div
          class="w-full flex flex-col lg:flex-row justify-between items-center gap-6 border-b border-white/5 pb-6"
        >
          <div class="flex items-center gap-6 flex-1">
            <div class="w-16 h-16 bg-white p-2 rounded-xl shrink-0 shadow-md">
              <img
                src="./pinguin-logo.svg"
                alt="Pinguin Icon"
                class="w-full h-full object-contain"
              />
            </div>
            <div class="flex flex-col gap-1">
              <h3 class="text-white text-2xl font-medium font-['Inter']">
                Проєкт Pinguin
              </h3>
              <p class="text-white/70 text-body-lg font-normal font-['Inter']">
                Система табелювання роботи працівників
              </p>
            </div>
          </div>
          <SocialBtn
            href="https://github.com/cherenov/Pinguin"
            platform="github"
            text="View on GitHub"
          />
        </div>

        <div
          class="w-full flex flex-col lg:flex-row justify-center items-center gap-8 filter drop-shadow-[0_25px_50px_rgba(0,0,0,0.6)]"
        >
          <div class="w-full max-w-[850px] aspect-[947/512] p-[1px]">
            <img
              src="./pinguin.webp"
              alt="Pinguin Web"
              class="w-full h-full object-contain"
            />
          </div>
          <div class="w-full max-w-[240px] aspect-[1/2] shrink-0 p-[1px]">
            <img
              src="./pinguin-2.webp"
              alt="Pinguin Mobile 1"
              class="w-full h-full object-contain"
            />
          </div>
        </div>

        <div
          class="w-full flex flex-wrap md:flex-nowrap justify-center items-center gap-6 md:gap-8 filter drop-shadow-[0_20px_40px_rgba(0,0,0,0.45)]"
        >
          <div class="w-2/5 max-w-[180px] aspect-[9/19] p-[1px]">
            <img src="./pinguin-3.webp" class="w-full h-full object-contain" />
          </div>
          <div class="w-2/5 max-w-[180px] aspect-[9/19] p-[1px]">
            <img src="./pinguin-4.webp" class="w-full h-full object-contain" />
          </div>
          <div class="w-2/5 max-w-[180px] aspect-[9/19] p-[1px]">
            <img src="./pinguin-5.webp" class="w-full h-full object-contain" />
          </div>
          <div
            class="w-full md:flex-1 h-auto max-w-[400px] md:max-w-none aspect-[16/9] p-[1px]"
          >
            <img
              loading="lazy"
              src="./pinguin-6.webp"
              alt="Workflow"
              class="w-full h-full object-cover rounded-sm border border-white/5"
            />
          </div>
        </div>

        <div
          class="w-full flex flex-wrap justify-center md:justify-start xl:justify-between items-center gap-x-4 gap-y-2 pt-4 border-t border-white/5 text-base font-['Inter']"
        >
          <div class="flex items-center">
            <span class="text-yellow-400 font-medium">[</span><span
              class="text-white/40 px-1">Flutter</span
            ><span class="text-yellow-400 font-medium">]</span>
          </div>
          <div class="flex items-center">
            <span class="text-yellow-400 font-medium">[</span><span
              class="text-white/40 px-1">GPS</span
            ><span class="text-yellow-400 font-medium">]</span>
          </div>
          <div class="flex items-center">
            <span class="text-yellow-400 font-medium">[</span><span
              class="text-white/40 px-1">Progressive Web App (PWA)</span
            ><span class="text-yellow-400 font-medium">]</span>
          </div>
          <div class="flex items-center">
            <span class="text-yellow-400 font-medium">[</span><span
              class="text-white/40 px-1">Authentication</span
            ><span class="text-yellow-400 font-medium">]</span>
          </div>
          <div class="flex items-center">
            <span class="text-yellow-400 font-medium">[</span><span
              class="text-white/40 px-1">Export to Excel / Google sheets</span
            ><span class="text-yellow-400 font-medium">]</span>
          </div>
          <div class="flex items-center">
            <span class="text-yellow-400 font-medium">[</span><span
              class="text-white/40 px-1">Firebase</span
            ><span class="text-yellow-400 font-medium">]</span>
          </div>
        </div>
      </div>

      <div
        data-layer="Linfo"
        class="w-full p-6 md:p-10 bg-white/5 rounded-sm border border-white/10 backdrop-blur-md flex flex-col gap-10 shadow-2xl"
      >
        <div
          class="w-full flex flex-col lg:flex-row justify-between items-center gap-6 border-b border-white/5 pb-6"
        >
          <div class="flex items-center gap-6 flex-1">
            <div
              class="w-16 h-16 bg-white p-2 rounded-xl shrink-0 shadow-md flex justify-center items-center"
            >
              <span class="text-black font-bold text-3xl font-['Inter']">L</span
              >
            </div>
            <div class="flex flex-col gap-1">
              <h3 class="text-white text-2xl font-medium font-['Inter']">
                Проєкт Linfo
              </h3>
              <p
                class="text-white/70 text-body-lg font-normal font-['Inter'] max-w-2xl"
              >
                MVP мобільного застосунку для відстеження уроків з автоматичним
                парсером розкладу та інтеграцією Google Meet.
              </p>
            </div>
          </div>
        </div>

        <div
          class="w-full flex flex-wrap justify-center items-center gap-6 md:gap-8 filter drop-shadow-[0_25px_50px_rgba(0,0,0,0.6)]"
        >
          <div class="w-[45%] sm:w-1/5 max-w-[200px] aspect-[9/19] p-[1px]">
            <img src="./linfo.webp" class="w-full h-full object-contain" />
          </div>
          <div class="w-[45%] sm:w-1/5 max-w-[200px] aspect-[9/19] p-[1px]">
            <img src="./linfo-2.webp" class="w-full h-full object-contain" />
          </div>
          <div class="w-[45%] sm:w-1/5 max-w-[200px] aspect-[9/19] p-[1px]">
            <img src="./linfo-3.webp" class="w-full h-full object-contain" />
          </div>
          <div class="w-[45%] sm:w-1/5 max-w-[200px] aspect-[9/19] p-[1px]">
            <img src="./linfo-4.webp" class="w-full h-full object-contain" />
          </div>
        </div>

        <div
          class="w-full flex flex-wrap justify-center md:justify-start xl:justify-between items-center gap-x-4 gap-y-2 pt-4 border-t border-white/5 text-base font-['Inter']"
        >
          <div class="flex items-center">
            <span class="text-yellow-400 font-medium">[</span><span
              class="text-white/40 px-1">Flutter</span
            ><span class="text-yellow-400 font-medium">]</span>
          </div>
          <div class="flex items-center">
            <span class="text-yellow-400 font-medium">[</span><span
              class="text-white/40 px-1">Python</span
            ><span class="text-yellow-400 font-medium">]</span>
          </div>
          <div class="flex items-center">
            <span class="text-yellow-400 font-medium">[</span><span
              class="text-white/40 px-1">Cross-platform</span
            ><span class="text-yellow-400 font-medium">]</span>
          </div>
          <div class="flex items-center">
            <span class="text-yellow-400 font-medium">[</span><span
              class="text-white/40 px-1">MVP</span
            ><span class="text-yellow-400 font-medium">]</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
